// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TASKER
  WORKER
}

enum Status {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum URGENCY {
  LOW
  MEDIUM
  HIGH
}

enum Appstatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  phoneNumber String
  bio         String
  role        Role     @default(WORKER)
  location    String
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userProfile WorkerProfile?

  createdJobs Job[] @relation("JobCreator")
  workJobs    Job[] @relation("JobWorker")

  applications Application[] @relation("UserApplications")

  givenReviews    reviews[] @relation("reviewerId")
  receivedReviews reviews[] @relation("revieweeId")
}

model WorkerProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  skills            String
  hourlyRate        Decimal
  totalJobCompleted Int      @default(0)
  averageRating     Decimal  @default(0)
  isAvailable       Boolean  @default(true)
  availability      String
  certifications    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Job {
  id               String  @id @default(uuid())
  userId           String
  selectedWorkerId String?
  title            String
  description      String
  category         String
  location         String
  latitude         Decimal
  longitude        Decimal

  startDate DateTime
  endDate   DateTime
  budget    Decimal

  status  Status  @default(OPEN)
  urgency URGENCY @default(MEDIUM)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User          @relation("JobCreator", fields: [userId], references: [id])
  selectedWorker User?         @relation("JobWorker", fields: [selectedWorkerId], references: [id])
  applications   Application[] @relation("JobApplications")
  reviews        reviews[]
}

model Application {
  id            String    @id @default(uuid())
  jobId         String
  workerId      String
  coverLetter   String?
  proposedPrice Decimal
  status        Appstatus @default(PENDING)

  appliedAt   DateTime  @default(now())
  respondedAt DateTime?

  job       Job  @relation("JobApplications", fields: [jobId], references: [id])
  applicant User @relation("UserApplications", fields: [workerId], references: [id])
}

model reviews {
  id         String   @id @default(uuid())
  jobId      String
  reviewerId String
  revieweeId String
  rating     Int      @default(0)
  comment    String
  createdAt  DateTime @default(now())
  reviewer   User     @relation("reviewerId", fields: [reviewerId], references: [id])
  reviewee   User     @relation("revieweeId", fields: [revieweeId], references: [id])
  job Job @relation(fields: [jobId], references: [id])
}
